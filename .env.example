# Qwen Cloud (Alibaba Cloud AI)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.7-max
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank

# Database (Alibaba Cloud RDS / local pgvector)
DATABASE_URL=postgresql+asyncpg://devmemory:devmemory_local@localhost:5432/devmemory

# Redis
REDIS_URL=redis://localhost:6379

# Alibaba Cloud
ALIBABA_ACCESS_KEY_ID=your_access_key_id
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_REGION=ap-southeast-1

# Memory tuning
MEMORY_DECAY_DEFAULT_RATE=0.1
MEMORY_IMPORTANCE_THRESHOLD=0.05
MEMORY_CONTEXT_MAX_TOKENS=8000
MEMORY_TOP_K=10
